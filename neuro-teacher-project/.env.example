# Шаблон переменных окружения для neuro-teacher-project.
# Скопируй в .env и заполни реальными значениями:
#   cp .env.example .env
# .env и .env.local в .gitignore — НЕ коммитить.

# === Генерация изображений (fal.ai) ===
FAL_KEY=

# === LLM через прокси (proxyapi.ru / OpenAI-совместимый) ===
PROXY_API_KEY=

# === VK API (автопубликация в сообщество) ===
# ID группы ВКонтакте (без минуса и без префикса "club")
VK_GROUP_ID=

# Пользовательский токен VK (получен через OAuth, руками)
# https://oauth.vk.com/blank.html#expires_in=0&access_token_XXXXXXXX=
VK_ACCESS_TOKEN=

# Альтернатива: токен сообщества (для wall.post от имени группы)
# VK_COMMUNITY_TOKEN=

# Параметры приложения VK ID (из настроек приложения)
# https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/start-integration/web-app
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_APP_SERVICE_KEY=

# Сервисные параметры
VK_AUTHORIZE_IP=         # IP сервера (для service token)
VK_REDIRECT_URI=         # https://your-domain/api/auth/vk-callback

# === Telegram Bot API ===
TELEGRAM_BOT_TOKEN=      # @BotFather → /newbot
TELEGRAM_CHAT_ID=@neuro_uchitel
